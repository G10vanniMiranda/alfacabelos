# Banco PostgreSQL/Supabase (obrigatório)
DATABASE_URL=postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@DB_HOST:5432/postgres

# URL pública usada em links de confirmação e recuperação (obrigatório em produção)
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Storage Supabase (obrigatório para galeria persistente)
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=galeria

# WhatsApp (opcional; habilite somente com todas as credenciais)
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=custom
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_OWNER_PHONE=
WHATSAPP_INSTANCE_ID=
WHATSAPP_WEBHOOK_SECRET=
BARBERSHOP_ADDRESS=

# Diagnóstico estruturado opcional
BOOKING_DIAGNOSTICS=false
