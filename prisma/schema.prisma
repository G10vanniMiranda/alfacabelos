generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BookingStatus {
  PENDENTE
  CONFIRMADO
  CANCELADO
  CONCLUIDO
  AUSENTE
}

enum AccessRole {
  ADMIN
  BARBER
}

enum NotificationStatus {
  NOT_CONFIGURED
  PENDING
  SENDING
  SENT
  FAILED
}

enum NotificationEvent {
  BOOKING_CREATED_BY_CLIENT
  BOOKING_CREATED_BY_STAFF
  BOOKING_RESCHEDULED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  PASSWORD_RESET
}

enum BookingPaymentStatus {
  PENDENTE
  CONFIRMADO
}

enum ClientStatus {
  PENDING
  ACTIVE
}

enum ClientCreatedBy {
  BARBER
  CLIENT
}

enum BookingCreatedBy {
  BARBER
  CLIENT
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum BookingSeriesStatus {
  ACTIVE
  CANCELLED
}

enum RecurrenceConflictPolicy {
  REJECT_ALL
}

model Barber {
  id            String               @id @default(cuid())
  name          String
  avatarUrl     String?
  isActive      Boolean              @default(true)
  bookings      Booking[]
  bookingSeries BookingSeries[]
  blocked       BlockedSlot[]
  availability  BarberAvailability[]
  access        AdminAccess?
}

model Service {
  id              String          @id @default(cuid())
  name            String
  durationMinutes Int
  isProcedure     Boolean         @default(false)
  priceCents      Int
  isActive        Boolean         @default(true)
  bookings        Booking[]
  bookingSeries   BookingSeries[]
}

model Booking {
  id                         String               @id @default(cuid())
  barberId                   String
  serviceId                  String
  clientId                   String?
  customerName               String
  customerPhone              String
  observations               String?
  dateTimeStart              DateTime
  dateTimeEnd                DateTime
  status                     BookingStatus        @default(PENDENTE)
  paymentStatus              BookingPaymentStatus @default(PENDENTE)
  paymentConfirmedAt         DateTime?
  confirmationToken          String?              @unique
  confirmationTokenHash      String?              @unique
  confirmationTokenExpiresAt DateTime?
  confirmationTokenUsedAt    DateTime?
  createdBy                  BookingCreatedBy     @default(CLIENT)
  createdAt                  DateTime             @default(now())
  seriesId                   String?
  occurrenceIndex            Int?
  occurrenceLocalDate        DateTime?            @db.Date

  barber        Barber                 @relation(fields: [barberId], references: [id])
  service       Service                @relation(fields: [serviceId], references: [id])
  client        Client?                @relation(fields: [clientId], references: [id], onDelete: SetNull)
  notifications NotificationDelivery[]
  series        BookingSeries?         @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@unique([seriesId, occurrenceLocalDate])
  @@index([barberId, dateTimeStart])
  @@index([clientId])
  @@index([status])
  @@index([paymentStatus])
  @@index([confirmationToken])
  @@index([confirmationTokenHash])
  @@index([seriesId])
}

model BookingSeries {
  id             String                   @id @default(cuid())
  barberId       String
  serviceId      String
  clientId       String?
  customerName   String
  customerPhone  String
  observations   String?
  frequency      RecurrenceFrequency
  interval       Int                      @default(1)
  weekdays       Int[]                    @default([])
  localTime      String
  timezone       String
  startsOn       DateTime                 @db.Date
  endsOn         DateTime                 @db.Date
  status         BookingSeriesStatus      @default(ACTIVE)
  conflictPolicy RecurrenceConflictPolicy @default(REJECT_ALL)
  idempotencyKey String                   @unique
  requestHash    String
  createdBy      BookingCreatedBy
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  barber   Barber    @relation(fields: [barberId], references: [id])
  service  Service   @relation(fields: [serviceId], references: [id])
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  bookings Booking[]

  @@index([barberId, startsOn, endsOn])
  @@index([clientId])
  @@index([status])
}

model NotificationDelivery {
  id              String             @id @default(cuid())
  event           NotificationEvent
  channel         String             @default("WHATSAPP")
  recipient       String
  recipientMasked String
  message         String
  context         String
  idempotencyKey  String             @unique
  status          NotificationStatus @default(PENDING)
  attempts        Int                @default(0)
  lastError       String?
  nextRetryAt     DateTime?
  sentAt          DateTime?
  bookingId       String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([status, nextRetryAt])
  @@index([bookingId, event])
}

model BlockedSlot {
  id            String   @id @default(cuid())
  barberId      String?
  dateTimeStart DateTime
  dateTimeEnd   DateTime
  reason        String
  createdAt     DateTime @default(now())

  barber Barber? @relation(fields: [barberId], references: [id])

  @@index([dateTimeStart])
}

model Client {
  id                  String               @id @default(cuid())
  name                String
  phone               String
  phoneNormalized     String               @unique
  passwordHash        String?
  hasPassword         Boolean              @default(true)
  status              ClientStatus         @default(ACTIVE)
  createdBy           ClientCreatedBy      @default(CLIENT)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  bookings            Booking[]
  bookingSeries       BookingSeries[]
  passwordResetTokens PasswordResetToken[]
  sessions            ClientSession[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  clientId  String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([expiresAt])
}

model ClientSession {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  clientId   String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([expiresAt])
}

model SecurityRateLimitEvent {
  id             String   @id @default(cuid())
  scope          String
  identifierHash String
  createdAt      DateTime @default(now())

  @@index([scope, identifierHash, createdAt])
  @@index([createdAt])
}

model AdminAccess {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  isActive     Boolean        @default(true)
  role         AccessRole     @default(ADMIN)
  barberId     String?        @unique
  lastLoginAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
  barber       Barber?        @relation(fields: [barberId], references: [id], onDelete: SetNull)

  @@index([role, isActive])
}

model AdminSession {
  id            String   @id @default(cuid())
  tokenHash     String   @unique
  adminAccessId String?
  email         String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  adminAccess AdminAccess? @relation(fields: [adminAccessId], references: [id], onDelete: SetNull)

  @@index([expiresAt])
}

model AdminLoginAttempt {
  id        String   @id @default(cuid())
  email     String
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

model GalleryImage {
  id        String   @id @default(cuid())
  imageUrl  String
  altText   String?
  mediaType String   @default("IMAGE")
  createdAt DateTime @default(now())
}

model BarberAvailability {
  id        String   @id @default(cuid())
  barberId  String
  dayOfWeek Int
  openTime  String
  closeTime String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek, openTime, closeTime])
  @@index([barberId])
}
