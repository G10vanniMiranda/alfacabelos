generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BookingStatus {
  PENDENTE
  CONFIRMADO
  CANCELADO
}

enum BookingPaymentStatus {
  PENDENTE
  CONFIRMADO
}

enum ClientStatus {
  PENDING
  ACTIVE
}

enum ClientCreatedBy {
  BARBER
  CLIENT
}

enum BookingCreatedBy {
  BARBER
  CLIENT
}

model Barber {
  id         String       @id @default(cuid())
  name       String
  avatarUrl  String?
  isActive   Boolean      @default(true)
  bookings   Booking[]
  blocked    BlockedSlot[]
  availability BarberAvailability[]
}

model Service {
  id              String    @id @default(cuid())
  name            String
  durationMinutes Int
  priceCents      Int
  isActive        Boolean   @default(true)
  bookings        Booking[]
}

model Booking {
  id             String        @id @default(cuid())
  barberId       String
  serviceId      String
  clientId       String?
  customerName   String
  customerPhone  String
  observations   String?
  dateTimeStart  DateTime
  dateTimeEnd    DateTime
  status         BookingStatus @default(PENDENTE)
  paymentStatus  BookingPaymentStatus @default(PENDENTE)
  paymentConfirmedAt DateTime?
  confirmationToken String? @unique
  confirmationTokenHash String? @unique
  confirmationTokenExpiresAt DateTime?
  confirmationTokenUsedAt DateTime?
  createdBy      BookingCreatedBy @default(CLIENT)
  createdAt      DateTime      @default(now())

  barber Barber @relation(fields: [barberId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([barberId, dateTimeStart])
  @@index([clientId])
  @@index([status])
  @@index([paymentStatus])
  @@index([confirmationToken])
  @@index([confirmationTokenHash])
}

model BlockedSlot {
  id            String   @id @default(cuid())
  barberId      String?
  dateTimeStart DateTime
  dateTimeEnd   DateTime
  reason        String
  createdAt     DateTime @default(now())

  barber Barber? @relation(fields: [barberId], references: [id])

  @@index([dateTimeStart])
}

model Client {
  id              String   @id @default(cuid())
  name            String
  phone           String
  phoneNormalized String   @unique
  passwordHash    String?
  hasPassword     Boolean  @default(true)
  status          ClientStatus @default(ACTIVE)
  createdBy       ClientCreatedBy @default(CLIENT)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  bookings        Booking[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  clientId  String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([expiresAt])
}

model SecurityRateLimitEvent {
  id             String   @id @default(cuid())
  scope          String
  identifierHash String
  createdAt      DateTime @default(now())

  @@index([scope, identifierHash, createdAt])
}

model AdminAccess {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sessions     AdminSession[]
}

model AdminSession {
  id            String      @id @default(cuid())
  tokenHash     String      @unique
  adminAccessId String?
  email         String
  expiresAt     DateTime
  createdAt     DateTime    @default(now())
  lastSeenAt    DateTime    @default(now())

  adminAccess AdminAccess? @relation(fields: [adminAccessId], references: [id], onDelete: SetNull)

  @@index([expiresAt])
}

model AdminLoginAttempt {
  id        String   @id @default(cuid())
  email     String
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

model GalleryImage {
  id        String   @id @default(cuid())
  imageUrl  String
  altText   String?
  mediaType String   @default("IMAGE")
  createdAt DateTime @default(now())
}

model BarberAvailability {
  id        String   @id @default(cuid())
  barberId  String
  dayOfWeek Int
  openTime  String
  closeTime String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek, openTime, closeTime])
  @@index([barberId])
}
